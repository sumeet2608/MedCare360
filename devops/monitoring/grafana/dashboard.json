  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Application Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 80 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "HTTP Request Rate",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"medcare-backend\"}[5m]))", "legendFormat": "req/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 1000 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "P95 Response Time",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket{job=\"medcare-backend\"}[5m])) by (le))", "legendFormat": "p95" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "CPU Usage",
      "type": "stat",
      "targets": [{ "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "title": "Request Rate Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"medcare-backend\",status=~\"2..\"}[5m]))", "legendFormat": "2xx" },
        { "expr": "sum(rate(http_requests_total{job=\"medcare-backend\",status=~\"4..\"}[5m]))", "legendFormat": "4xx" },
        { "expr": "sum(rate(http_requests_total{job=\"medcare-backend\",status=~\"5..\"}[5m]))", "legendFormat": "5xx" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "title": "Memory Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"medcare-backend\"} / 1024 / 1024", "legendFormat": "RSS MB" },
        { "expr": "process_heap_bytes{job=\"medcare-backend\"} / 1024 / 1024", "legendFormat": "Heap MB" }
      ]
    }
  ],
  "refresh": "30s",
