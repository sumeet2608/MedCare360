# MedCare360 — Required Environment Variables
# Copy this file to .env and fill in all values before running docker-compose
# NEVER commit .env to version control

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
FRONTEND_URL=http://localhost:4200
PORT=5000

# ── Authentication (generate with: openssl rand -hex 64) ─────────────────────
JWT_SECRET=<generate-min-64-char-random-string>
JWT_REFRESH_SECRET=<generate-min-64-char-random-string>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_PASSWORD=<strong-password>
MONGODB_URI=mongodb://admin:<password>@localhost:27017/medcare360?authSource=admin
# For production Atlas:
MONGODB_URI_PROD=mongodb+srv://<user>:<pass>@cluster.mongodb.net/medcare360

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<strong-password>

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=<gmail-app-password>

# ── AWS (for S3 uploads and Secrets Manager) ──────────────────────────────────
AWS_ACCESS_KEY_ID=<iam-access-key>
AWS_SECRET_ACCESS_KEY=<iam-secret-key>
AWS_REGION=us-east-1
AWS_S3_BUCKET=medcare360-uploads

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=500

# ── Monitoring (optional) ─────────────────────────────────────────────────────
# JAEGER_ENDPOINT=http://localhost:14268/api/traces
